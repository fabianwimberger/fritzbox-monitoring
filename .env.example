# FritzBox connection settings
FRITZBOX_IP=192.168.178.1
FRITZBOX_USER=your-fritzbox-username
FRITZBOX_PASSWORD=your-fritzbox-password

# Ping target (optional, defaults to 1.1.1.1)
PING_TARGET=1.1.1.1

# Exporter HTTP port (optional, defaults to 8000)
PORT=8000

# State file path (optional, defaults to /app/data/fritzbox_exporter_state.json)
STATE_FILE=/app/data/fritzbox_exporter_state.json

# LAN host refresh interval in seconds (optional, defaults to 180)
LAN_HOST_INTERVAL_SECONDS=180
